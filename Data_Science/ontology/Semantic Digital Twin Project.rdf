<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1/"
     xml:base="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:trail1="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1_version2">
        <owl:imports rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#affectsProcess -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#affectsProcess">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RawMaterial"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#ProductionProcess"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#appliesTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#appliesTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#followsRoute -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#followsRoute">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#fulfills -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#fulfills">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#PurchaseOrder"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#governs -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#governs">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasSLA"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasSLA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasSLA">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#impacts -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#impacts">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#ProductionDisruption"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#ProductionProcess"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#incursPenalty -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#incursPenalty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RiskEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLAViolation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isPerformedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isPerformedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#performsDeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#LogisticsProvider"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isSuppliedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isSuppliedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#supplies"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RawMaterial"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isTriggeredBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#isTriggeredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#issuedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#issuedTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#PurchaseOrder"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#managesRoute -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#managesRoute">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#performsDeliveryEvent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#performsDeliveryEvent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#receivesInstructionsFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#receivesInstructionsFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#replaces -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#replaces">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#AlternativeSupplier"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#IncumbentSupplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#supplies -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#supplies">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#suppliesSameMaterialAs -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#suppliesSameMaterialAs">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#AlternativeSupplier"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#IncumbentSupplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#transports -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#transports">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#utilizesRoute -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#utilizesRoute">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#BusinessActor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Supplier"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Route"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasActualArrivalDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasActualArrivalDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasActualDepartureTime -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasActualDepartureTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasContractID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasContractID">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasCriticalityLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasCriticalityLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#ProductionDisruption"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RiskEvent"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Critical</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>High</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Low</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Medium</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasCurrency -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasCurrency">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDelayDuration -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDelayDuration">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DelayEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDelayPenaltyRate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDelayPenaltyRate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDeliveredQuantity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDeliveredQuantity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDeliveryStatus -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#hasDeliveryStatus">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/youssef/ontologies/2026/1/trail1#Event"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Delayed</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Delivered</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Scheduled</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Shipped</rdf:first>
